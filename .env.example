# ─── Echo Maps Environment Configuration ───
# Copy to .env and fill in your values

# ── Application ──
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Google OAuth 2.0 ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://echo:echo@localhost:5432/echo_maps

# ── Milvus Vector DB ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rf_signatures

# ── Google Cloud Storage ──
GCS_BUCKET=echo-maps-environments
GCS_CREDENTIALS_PATH=

# ── AI Engine ──
MODEL_CACHE_DIR=./models
CSI_SAMPLE_RATE_HZ=100
CALIBRATION_CONFIDENCE_THRESHOLD=0.95
LATENT_DIM=512

# ── Federated Learning ──
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_MIN_CLIENTS=2
FL_ROUNDS=10

# ── TLS ──
TLS_CERT_PATH=
TLS_KEY_PATH=
